{
  "name": "@ssurak/frontend",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:order": "turbo run dev --filter=@ssurak/order",
    "dev:console": "turbo run dev --filter=@ssurak/console",
    "build:order": "turbo run build --filter=@ssurak/order",
    "build:console": "turbo run build --filter=@ssurak/console",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22"
  }
}
