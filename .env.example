# DB config
DB_ROOT_PASSWORD=<auto-generated>
DB_NAME=spaceorder
DB_USER=spaceorder
DB_PASSWORD=<auto-generated>
DATABASE_URL=mysql://spaceorder:<auto-generated>@localhost:3306/spaceorder?connection_limit=10&pool_timeout=10

# JWT config
JWT_ACCESS_TOKEN_SECRET=<auto-generated>
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# JWT payload config
JWT_REFRESH_TOKEN_SECRET=<auto-generated>
JWT_ISSUER=https://api.ssurak.com/auth
JWT_AUDIENCE=console-api

# Redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<auto-generated>

# Server config
SERVER_PORT=8080

# Cookie config
COOKIE_DOMAIN=.ssurak.com

# Frontend app URLs (api.ssurak.com CORS + WS origin 식별용)
ORDER_APP_URL=http://localhost:3000
CONSOLE_APP_URL=http://localhost:3001

# API URL (브라우저 클라이언트용)
NEXT_PUBLIC_API_SSURAK_URL=http://localhost:8080
NEXT_PUBLIC_ORDER_APP_URL=http://localhost:3000
