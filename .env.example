# DB config
DB_ROOT_PASSWORD=<auto-generated>
DB_NAME=spaceorder
DB_USER=spaceorder
DB_PASSWORD=<auto-generated>
DATABASE_URL=mysql://spaceorder:<auto-generated>@localhost:3306/spaceorder?connection_limit=10&pool_timeout=10

# JWT config
JWT_ACCESS_TOKEN_SECRET=<auto-generated>
JWT_ACCESS_TOKEN_EXPIRATION_MS=3600000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# JWT payload config
JWT_REFRESH_TOKEN_SECRET=<auto-generated>
JWT_ISSUER=http://spaceorder-orderhub.com/auth
JWT_AUDIENCE=spaceorder-orderdesk

# Redis config
# 로컬 개발 기본값: localhost
# Docker compose 사용 시에는 REDIS_HOST=redis 로 오버라이드하여 사용합니다.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<auto-generated>

# Server config
SERVER_PORT=8080

# API URL (브라우저 클라이언트용)
NEXT_PUBLIC_ORDERHUB_URL=http://localhost:8080
