# 컨테이너에서 설치/생성하거나 빌드에 불필요한 항목 제외.
# 특히 node_modules 를 제외해야 deps 단계에서 설치한 (올바른 아키텍처의)
# node_modules 와 Prisma client 가 COPY . . 로 덮어써지지 않는다.
**/node_modules
**/.next
**/dist
**/.turbo
.turbo

# VCS / 메타
.git
.gitignore
.github

# 로컬 산출물 / 잡파일
spaceorder_output
**/*.log
**/.DS_Store

# Docker 관련 (컨텍스트에 불필요)
Dockerfile
**/Dockerfile
docker-compose*.yml
.dockerignore
k8s
